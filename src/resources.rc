#include <windows.h>
#include <commctrl.h>

#define APP_ICON_RESOURCE_ID 1
#define APP_CTRL_DEBUG_TEXT 2001
#define APP_CTRL_DEBUG_PAUSE 2002
#define APP_CTRL_DEBUG_STEP 2003
#define APP_CTRL_DEBUG_STEP_OVER 2004
#define APP_CTRL_DEBUG_REFRESH 2005
#define APP_CTRL_DEBUG_ADDRESS 2006
#define APP_CTRL_DEBUG_GO 2007
#define APP_CTRL_DEBUG_SYNC 2008
#define APP_CTRL_DEBUG_BREAKPOINT_TOGGLE 2009
#define APP_CTRL_DEBUG_RUN_AT 2010
#define APP_CTRL_DEBUG_RUN_TO 2011
#define APP_CTRL_DEBUG_WATCHPOINT_TOGGLE 2012
#define APP_CTRL_DEBUG_REMOVE_SELECTED 2013
#define APP_CTRL_DEBUG_POINTS_LIST 2014
#define APP_CTRL_DEBUG_VIEW_PC 2015
#define APP_CTRL_DEBUG_VIEW_SP 2016
#define APP_CTRL_DEBUG_PAGE_UP 2017
#define APP_CTRL_DEBUG_PAGE_DOWN 2018
#define APP_CTRL_DEBUG_REGISTERS 2019
#define APP_CTRL_DEBUG_MEMORY 2020
#define APP_CTRL_DEBUG_DISASSEMBLY_GROUP 2021
#define APP_CTRL_DEBUG_REGISTERS_GROUP 2022
#define APP_CTRL_DEBUG_MEMORY_GROUP 2023
#define APP_CTRL_DEBUG_POINTS_GROUP 2024
#define APP_CTRL_DEBUG_STACK 2025
#define APP_CTRL_DEBUG_STACK_GROUP 2026
#define APP_CTRL_ASM_SOURCE 2102
#define APP_CTRL_ASM_STATUS 2104
#define APP_CTRL_POKE_ADDRESS 2110
#define APP_CTRL_POKE_VALUES 2111
#define APP_CTRL_POKE_APPLY 2112
#define APP_CTRL_POKE_ADDRESS_LABEL 2114
#define APP_CTRL_POKE_VALUES_LABEL 2115
#define APP_DIALOG_DEBUGGER 4001
#define APP_DIALOG_ASSEMBLER 4002
#define APP_DIALOG_POKE 4003

APP_ICON_RESOURCE_ID ICON "assets/zxspecemu.ico"

APP_DIALOG_DEBUGGER DIALOGEX 0, 0, 260, 160
STYLE WS_CHILD | WS_VISIBLE | DS_CONTROL
EXSTYLE WS_EX_CONTROLPARENT
FONT 9, "Segoe UI"
BEGIN
    PUSHBUTTON "Pause", APP_CTRL_DEBUG_PAUSE, 4, 4, 24, 14, BS_FLAT
    PUSHBUTTON "Step", APP_CTRL_DEBUG_STEP, 30, 4, 24, 14, BS_FLAT
    PUSHBUTTON "Step Over", APP_CTRL_DEBUG_STEP_OVER, 56, 4, 30, 14, BS_FLAT
    PUSHBUTTON "Refresh", APP_CTRL_DEBUG_REFRESH, 88, 4, 26, 14, BS_FLAT
    CONTROL "", APP_CTRL_DEBUG_ADDRESS, "Edit", WS_VISIBLE | WS_TABSTOP | WS_BORDER | ES_AUTOHSCROLL | ES_UPPERCASE, 116, 4, 32, 14
    PUSHBUTTON "Go", APP_CTRL_DEBUG_GO, 150, 4, 18, 14, BS_FLAT
    PUSHBUTTON "Run To", APP_CTRL_DEBUG_RUN_TO, 170, 4, 24, 14, BS_FLAT
    PUSHBUTTON "Run @", APP_CTRL_DEBUG_RUN_AT, 196, 4, 24, 14, BS_FLAT
    CONTROL "Sync PC", APP_CTRL_DEBUG_SYNC, "Button", WS_TABSTOP | BS_AUTOCHECKBOX | BS_FLAT, 222, 4, 30, 14
    PUSHBUTTON "Toggle BP", APP_CTRL_DEBUG_BREAKPOINT_TOGGLE, 4, 22, 34, 14, BS_FLAT
    PUSHBUTTON "Toggle WP", APP_CTRL_DEBUG_WATCHPOINT_TOGGLE, 40, 22, 34, 14, BS_FLAT
    PUSHBUTTON "Remove Sel", APP_CTRL_DEBUG_REMOVE_SELECTED, 76, 22, 38, 14, BS_FLAT
    PUSHBUTTON "PC", APP_CTRL_DEBUG_VIEW_PC, 116, 22, 16, 14, BS_FLAT
    PUSHBUTTON "SP", APP_CTRL_DEBUG_VIEW_SP, 134, 22, 16, 14, BS_FLAT
    PUSHBUTTON "Page -", APP_CTRL_DEBUG_PAGE_UP, 152, 22, 24, 14, BS_FLAT
    PUSHBUTTON "Page +", APP_CTRL_DEBUG_PAGE_DOWN, 178, 22, 24, 14, BS_FLAT
    GROUPBOX "Disassembly", APP_CTRL_DEBUG_DISASSEMBLY_GROUP, 4, 40, 124, 56, BS_FLAT
    CONTROL "", APP_CTRL_DEBUG_TEXT, "Scintilla", WS_VISIBLE | WS_TABSTOP | WS_BORDER | WS_CLIPCHILDREN, 8, 50, 116, 42
    GROUPBOX "Registers", APP_CTRL_DEBUG_REGISTERS_GROUP, 132, 40, 124, 34, BS_FLAT
    CONTROL "", APP_CTRL_DEBUG_REGISTERS, "Edit", WS_VISIBLE | WS_TABSTOP | WS_BORDER | WS_VSCROLL | ES_MULTILINE | ES_AUTOVSCROLL | ES_READONLY, 136, 50, 116, 20
    GROUPBOX "Breakpoints && watchpoints", APP_CTRL_DEBUG_POINTS_GROUP, 132, 76, 60, 64, BS_FLAT
    LISTBOX APP_CTRL_DEBUG_POINTS_LIST, 136, 86, 52, 50, WS_VISIBLE | WS_TABSTOP | WS_BORDER | WS_VSCROLL | LBS_NOTIFY | LBS_NOINTEGRALHEIGHT
    GROUPBOX "Memory", APP_CTRL_DEBUG_MEMORY_GROUP, 196, 76, 38, 64, BS_FLAT
    CONTROL "", APP_CTRL_DEBUG_MEMORY, "Scintilla", WS_VISIBLE | WS_TABSTOP | WS_BORDER | WS_CLIPCHILDREN, 200, 86, 52, 50
    GROUPBOX "Stack", APP_CTRL_DEBUG_STACK_GROUP, 236, 76, 20, 64, BS_FLAT
    CONTROL "", APP_CTRL_DEBUG_STACK, "Scintilla", WS_VISIBLE | WS_TABSTOP | WS_BORDER | WS_CLIPCHILDREN, 240, 86, 12, 50
END

APP_DIALOG_ASSEMBLER DIALOGEX 0, 0, 220, 150
STYLE WS_CHILD | WS_VISIBLE | WS_CLIPCHILDREN | DS_CONTROL
EXSTYLE WS_EX_CONTROLPARENT
FONT 9, "Segoe UI"
BEGIN
    CONTROL "", APP_CTRL_ASM_SOURCE, "Scintilla", WS_VISIBLE | WS_TABSTOP | WS_CLIPCHILDREN, 0, 0, 220, 120
    CONTROL "", APP_CTRL_ASM_STATUS, "msctls_statusbar32", WS_VISIBLE | SBARS_SIZEGRIP, 0, 130, 220, 12
END

APP_DIALOG_POKE DIALOGEX 0, 0, 120, 72
STYLE WS_CHILD | WS_VISIBLE | DS_CONTROL
EXSTYLE WS_EX_CONTROLPARENT
FONT 9, "Segoe UI"
BEGIN
    LTEXT "Address:", APP_CTRL_POKE_ADDRESS_LABEL, 4, 4, 30, 10
    CONTROL "", APP_CTRL_POKE_ADDRESS, "Edit", WS_VISIBLE | WS_GROUP | WS_TABSTOP | WS_BORDER | ES_AUTOHSCROLL | ES_UPPERCASE, 36, 4, 70, 14
    LTEXT "Values:", APP_CTRL_POKE_VALUES_LABEL, 4, 22, 30, 10
    CONTROL "", APP_CTRL_POKE_VALUES, "Edit", WS_VISIBLE | WS_TABSTOP | WS_BORDER | ES_AUTOHSCROLL | ES_WANTRETURN, 36, 22, 70, 14
    PUSHBUTTON "Apply", APP_CTRL_POKE_APPLY, 70, 44, 36, 14, BS_FLAT
END
